generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(uuid())
  username           String
  email              String         @unique
  passwordHash       String
  city               String
  childAge           String?
  role               UserRole       @default(MEMBER)
  badges             Json?
  createdAt          DateTime       @default(now())
  isVerified         Boolean        @default(false)
  postCount          Int            @default(0)
  replyCount         Int            @default(0)
  totalUpvotes       Int            @default(0)
  trustScore         Int            @default(0)
  emailNotifications Boolean        @default(true)
  savedPosts         Int[]
  chatSessions       ChatSession[]
  conversations      Conversation[]
  notifications      Notification[]
  replies            Reply[]
  votes              Vote[]
}

model Conversation {
  id               Int              @id @default(autoincrement())
  title            String
  category         String
  isPinned         Boolean          @default(false)
  isHot            Boolean          @default(false)
  isFeatured       Boolean          @default(false)
  featuredLabel    String?
  votes            Int              @default(0)
  views            Int              @default(0)
  opAuthor         String
  opCity           String
  opTime           String
  opText           String
  opImage          String?
  opAuthorRole     UserRole         @default(MEMBER)
  opAuthorBadges   String[]
  moderationStatus ModerationStatus @default(PENDING)
  moderatedBy      String?
  moderationReason String?
  createdAt        DateTime         @default(now())
  authorId         String
  greyAreaFlags    String[]
  reviewPriority   Int?
  author           User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies          Reply[]
  votesRelation    Vote[]           @relation("VoteToConversation")
}

model Reply {
  id               Int              @id @default(autoincrement())
  conversationId   Int
  author           String
  authorId         String
  city             String
  time             String
  text             String
  image            String?
  likes            Int              @default(0)
  authorRole       UserRole         @default(MEMBER)
  authorBadges     String[]
  moderationStatus ModerationStatus @default(PENDING)
  parentId         Int?
  createdAt        DateTime         @default(now())
  authorUser       User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  conversation     Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent           Reply?           @relation("ReplyToReply", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Reply[]          @relation("ReplyToReply")
  votesRelation    Vote[]           @relation("VoteToReply")
}

model Vote {
  id             String        @id @default(uuid())
  userId         String
  conversationId Int?
  replyId        Int?
  type           VoteType
  createdAt      DateTime      @default(now())
  conversation   Conversation? @relation("VoteToConversation", fields: [conversationId], references: [id], onDelete: Cascade)
  reply          Reply?        @relation("VoteToReply", fields: [replyId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          Int              @id @default(autoincrement())
  userId      String
  type        NotificationType
  title       String
  description String
  time        String
  read        Boolean          @default(false)
  threadId    Int?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id         String        @id @default(uuid())
  userId     String
  createdAt  DateTime      @default(now())
  lastActive DateTime      @default(now())
  messages   ChatMessage[]
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      ChatRole
  content   String
  timestamp DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ModerationLog {
  id          String           @id @default(uuid())
  moderatorId String
  targetType  ModerationTarget
  targetId    Int
  action      ModerationAction
  reason      String?
  timestamp   DateTime         @default(now())
}

model Category {
  id        String @id
  label     String
  icon      String
  className String
  count     Int    @default(0)
  bg        String
  text      String
  border    String
}

model Product {
  id       String @id
  name     String
  icon     String
  subtitle String
  tag      String
  price    String
  linkUrl  String
}

model EmailLog {
  id      String    @id @default(uuid())
  type    EmailType
  to      String
  subject String
  sentAt  DateTime  @default(now())
  preview String
}

enum UserRole {
  GUEST
  MEMBER
  TRUSTED
  MODERATOR
  TUCO_TEAM
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum VoteType {
  UP
  DOWN
}

enum NotificationType {
  REPLY
  LIKE
  BADGE
  SYSTEM
}

enum ChatRole {
  USER
  ASSISTANT
}

enum ModerationTarget {
  CONVERSATION
  REPLY
}

enum ModerationAction {
  APPROVED
  REJECTED
  FLAGGED
}

enum EmailType {
  APPROVAL
  WEEKLY_ENGAGEMENT
  LAUNCH
}
