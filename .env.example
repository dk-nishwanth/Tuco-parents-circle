# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (Required for production)
# ─────────────────────────────────────────────────────────────────────────────
# Get this from: https://neon.tech
# Create free PostgreSQL database and copy the connection string
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# SERVER (Required)
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="3002"

# JWT_SECRET: Generate with: openssl rand -base64 32
# Keep this secret! Used for signing authentication tokens
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# ─────────────────────────────────────────────────────────────────────────────
# AI CHATBOT (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Get free API key from: https://console.anthropic.com
# Without this, chatbot uses keyword-based fallback
# ANTHROPIC_API_KEY="sk-ant-v0-xxxxx"

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Get free API key from: https://resend.com
# 3,000 emails/month free
# Without this, emails are simulated and logged
# RESEND_API_KEY="re_xxxxx"
# EMAIL_FROM="noreply@tucokids.com"

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Optional - if frontend is deployed separately)
# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND_URL="https://tuco-parents-circle.onrender.com"

# ─────────────────────────────────────────────────────────────────────────────
# SHOPIFY INTEGRATION (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# SHOPIFY_API_SECRET="your-shopify-secret"
# VITE_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
# VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN="xxxxx"
